    <script>
        function fetchWithErrorHandler(url, options) {
            return fetch(url, options)
                .then(response => {
                    if (!response.ok && response.status === 400) {
                        return response.json().then(err => {
                            throw new Error(err.message);
                        });
                    }
                    return response.json();
                })
                .then(data => {
                    // Close the modal
                    $('#composeModal').modal('hide');
                    $('#editModal').modal('hide');
                    $('.modal-backdrop').remove();
                    // Clear the form fields
                    $('#regbookform').find('input:not([type=submit]),textarea,select').val('');
                    $('#editbookform').find('input:not([type=submit]),textarea,select').val('');
                    // The request was successful, update the table here
                    if (data.success) {
                        const tableBody = document.querySelector('#dataTable tbody');
                        if (!(tableBody instanceof HTMLTableSectionElement)) {
                            console.error('tableBody is not a reference to a tbody element');
                            return;
                        }
                        tableBody.innerHTML = ''; // Clear the table body
                        data.data.forEach(item => {
                            const tr = document.createElement('tr');

                            // Create checkbox cell
                            const checkboxCell = document.createElement('td');
                            const checkbox = document.createElement('input');
                            checkbox.type = 'checkbox';
                            checkbox.className = 'selectRow';
                            checkbox.name = 'bookidhidden';
                            checkbox.value = item.Book_id;
                            checkboxCell.appendChild(checkbox);
                            tr.appendChild(checkboxCell);
                            // Create text cells
                            ['Book_id', 'Title', 'Author_ID', 'Publisher_ID', 'Language', 'Copies_Available', 'Book_Status'].forEach(key => {
                                const td = document.createElement('td');
                                td.textContent = item[key];
                                tr.appendChild(td);
                            });

                            // Create dropdown cell
                            const dropdownCell = document.createElement('td');
                            // Add your dropdown HTML here
                            dropdownCell.innerHTML = `
                                <div class="dropdown">
                                    <button class="btn btn-primary dropdown-toggle" type="button" id="dropdownMenuButton" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        Action
                                    </button>
                                    <div class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                                        <a class="btn btn-primary dropdown-item edit-item" data-toggle="modal" data-target="#editModal" href="#">
                                            <i class='bx-fw bx bxs-edit'></i>
                                            Edit
                                        </a>
                                        <a class="btn btn-primary dropdown-item delete-item" data-toggle="modal" data-target="#deleteModal" href="#">
                                            <i class='bx-fw bx bxs-trash'></i>
                                            Delete
                                        </a>
                                    </div>
                                </div>
                            `;
                            tr.appendChild(dropdownCell);
                            tableBody.appendChild(tr);
                        });
                    } else {
                        // Handle the error here
                        throw new Error(data.message);
                    }
                })
                .catch(error => {
                    // Show your modal here
                    $('#errorModal .modal-body').text(error.message);
                    $('#errorModal').modal('show');
                });
        }
        $(document).ready(function() {
            $('#selectAll').on('change', function() {
                $('.selectRow').prop('checked', this.checked);
            });

            // Initially hide the delete button
            $('.delrowall').hide();

            // Show or hide the delete button when a checkbox is clicked
            $('.selectRow').on('change', function() {
                if ($('.selectRow:checked').length > 0) {
                    // If any checkboxes are checked, show the delete button
                    $('.delrowall').show();
                } else {
                    // If no checkboxes are checked, hide the delete button
                    $('.delrowall').hide();
                }
            });

            // Show or hide the delete button when the "select all" checkbox is clicked
            $('#selectAll').on('change', function() {
                if (this.checked) {
                    // If the "select all" checkbox is checked, show the delete button
                    $('.delrowall').show();
                } else {
                    // If the "select all" checkbox is unchecked, hide the delete button
                    $('.delrowall').hide();
                }
            });

            $('#composeModal').on('click', function(e) {
                e.stopPropagation();
            });

            $('.edit-item').on('click', function(e) {
                // e.stopPropagation();
                // Handle edit action here
                console.log('Edit clicked');
                var row = $(this).closest('tr');
                var id = row.find('td:eq(1)').text();
                var Title = row.find('td:eq(2)').text();
                var AuthorID = row.find('td:eq(3)').text();
                var PublisherID = row.find('td:eq(4)').text();
                var Language = row.find('td:eq(5)').text();
                var Copies = row.find('td:eq(6)').text();
                var Status = row.find('td:eq(7)').text();

                $('#editModal input[name="bookidhidden"]').val(id);
                $('#editModal input[name="editbooktitle"]').val(Title);
                $('#editModal input[name="autidhidden"]').val(AuthorID);
                $('#editModal input[name="pubidhidden"]').val(PublisherID);
                $('#editModal input[name="editbooklanguage"]').val(Language);
                $('#editModal input[name="editbookcopies"]').val(Copies);
                $('#editModal select[name="editbookstatus"]').val(Status);
            });
    
            $('.delete-item').on('click', function(e) {
                e.preventDefault();
                $(this).closest('tr').find('.selectRow').prop('checked', true);
                var ids = $('.selectRow:checked').map(function() {
                    return $(this).closest('tr').find('td:eq(1)').text();
                }).get();
                if(ids.length === 0) {
                    alert('Please select at least one book to delete.');
                    return;
                }
                $('#deleteModal input[name="bookidhidden"]').val(JSON.stringify(ids));
            });

            $('#regbookform').on('submit', function(e) {
                e.preventDefault();
                var dataToSend = $(this).serialize();
                // Make a request to the server to register a publisher
                fetchWithErrorHandler('/regNovelBook', {
                    method: 'POST',
                    headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: dataToSend,
                })
            });

            $('#editbookform').on('submit', function(e) {
                e.preventDefault();
                var dataToSend = $(this).serialize();
                // Make a request to the server to register a publisher
                fetchWithErrorHandler('/editNovelBook', {
                    method: 'POST',
                    headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: dataToSend
                })
            });
    
            $('#dataTable tbody tr').on('click', function() {
                $(this).find('.dropdown-toggle').dropdown('toggle');
            });
            // Close dropdowns when clicking outside of them
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.dropdown').length) {
                    $('.dropdown').find('.dropdown-toggle').dropdown('hide');
                }
            });

            $('tr').contextmenu(function(e) {
                e.preventDefault();
                $(this).find('.dropdown-toggle').dropdown('toggle');
            });
        });
    </script>
</head>
<body>
