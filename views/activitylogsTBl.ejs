<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Admin Dashboard</title>
    <link rel="icon" href="/images/logo2.png"/>
    <link rel="stylesheet" href="/css/sidebar.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel='stylesheet' href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css'/>
    <link href="/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#selectAll').on('change', function() {
                $('.selectRow').prop('checked', this.checked);
            });

            // Initially hide the delete button
            $('.delrowall').hide();

            // Show or hide the delete button when a checkbox is clicked
            $('.selectRow').on('change', function() {
                if ($('.selectRow:checked').length > 0) {
                    // If any checkboxes are checked, show the delete button
                    $('.delrowall').show();
                } else {
                    // If no checkboxes are checked, hide the delete button
                    $('.delrowall').hide();
                }
            });

            // Show or hide the delete button when the "select all" checkbox is clicked
            $('#selectAll').on('change', function() {
                if (this.checked) {
                    // If the "select all" checkbox is checked, show the delete button
                    $('.delrowall').show();
                } else {
                    // If the "select all" checkbox is unchecked, hide the delete button
                    $('.delrowall').hide();
                }
            });

            $('.delete-item').on('click', function(e) {
                e.preventDefault();
                $(this).closest('tr').find('.selectRow').prop('checked', true);
                var ids = $('.selectRow:checked').map(function() {
                    return $(this).closest('tr').find('td:eq(1)').text();
                }).get();
                if(ids.length === 0) {
                    alert('Please select at least one book to delete.');
                    return;
                }
                $('#deleteModal input[name="logidhidden"]').val(JSON.stringify(ids));
            });
        });
    </script>
</head>
<body>
