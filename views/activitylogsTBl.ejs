                        </li>
                    </ul>
                </li>
                <li>
                    <div class="profile-details">
                        <div class="profile-content">
                            <img class="logo" src="images/logo2.png" alt="Veritas Logo">
                        </div>
                        <div class="name-job">
                            <div class="profile_name"><%= user ? user.Name : 'Admin' %></div>
                            <div class="job"><%= user ? user.User_Role : 'Admin' %></div>
                        </div>
