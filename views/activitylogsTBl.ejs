                    </div>
                </li>
            </ul>
        </div>
        <section class="home-section">
            <div class="home-content">
                <i class='bx bx-menu' ></i>
                <span class="text">Activity Logs</span>
            </div>
            <!-- <img src="images/bg4.png" alt="Veritas Logo"> -->
            <div class="tbltbl">
                <div class="container-fluid">
                    <div class="card shadow mb-4">
                        <div class="card-header py-3">
                            <h6 class="m-0 font-weight-bold text-primary">Log's Data</h6>
                            <div class="twobtn">
                                <a class="btn btn-primary delrowall delete-item" data-toggle="modal" data-target="#deleteModal" href="#">
                                    <i class='bx-fw bx bxs-trash bx-tada-hover'></i>
                                    Delete
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                                    <thead>
                                      <tr>
                                        <th><input type="checkbox" id="selectAll"></th>
                                        <th>ObjectId</th>
                                        <th>ID</th>
                                        <th>Action</th>
                                        <th>Date</th>
                                        <th>Details</th>
                                      </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                            <th></th>
                                            <th>ObjectId</th>
                                            <th>ID</th>
                                            <th>Action</th>
                                            <th>Date</th>
                                            <th>Details</th>
                                        </tr>
                                    </tfoot>
                                    <tbody>
                                      <% data.forEach(item => { %>
                                        <tr>
                                            <td><input type="checkbox" class="selectRow" name="logidhidden" value="<%= item._id %>"></td>
                                            <td><%= item._id %></td>
                                            <td><%= item.User_ID %></td>
                                            <td><%= item.action %></td>
                                            <td><%= item.timestamp %></td>
                                            <td><%= item.details %></td>
                                        </tr>
                                      <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <div class="modal fade" id="logoutModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
            aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel">Ready to Leave?</h5>
                        <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">×</span>
                        </button>
                    </div>
                    <div class="modal-body">Select "Logout" below if you are ready to end your current session.</div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                        <a class="btn btn-primary" href="/logout">Logout</a>
                    </div>
                </div>
            </div>
        </div>
        <form action="/delLogs" method="post">
            <div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="exampleModalLabel">Are you sure?</h5>
                            <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">×</span>
                            </button>
                        </div>
                        <div class="modal-body">Select "Delete" below if you are ready to delete this user</div>
                        <input type="hidden" name="logidhidden">
                        <div class="modal-footer">
                            <button class="btn btn-secondary" type="button" data-dismiss="modal">Cancel</button>
                            <input class="btn btn-primary" type="submit" href="/delLogs"></input>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
    <script src="/js/veritas.js"></script>
    
    <!-- Core JavaScript-->
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript-->
